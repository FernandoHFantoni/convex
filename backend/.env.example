# Banco de dados (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/convex

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=sua-string-aleatoria-de-128-chars

# Criptografia para tokens OAuth — gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=sua-string-de-64-chars-hex

# URLs
API_URL=https://convex-api.up.railway.app
FRONTEND_URL=https://convex.vercel.app

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Meta Ads (developers.facebook.com)
META_APP_ID=
META_APP_SECRET=

# Google Ads (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# TikTok (ads.tiktok.com/marketing_api)
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

# Mercado Livre (developers.mercadolivre.com.br)
ML_APP_ID=
ML_APP_SECRET=

# Amazon Ads (advertising.amazon.com)
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
